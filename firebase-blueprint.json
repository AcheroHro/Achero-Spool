{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A collection of related pipe spools.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the project" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this project" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Spool": {
      "title": "Pipe Spool",
      "description": "A specific pipe spool design.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "Reference to the parent project" },
        "name": { "type": "string", "description": "Name of the spool" },
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "drawingData": { 
          "type": "object", 
          "description": "Serialized Konva state or custom drawing structure" 
        },
        "bom": {
          "type": "array",
          "description": "Automatically calculated Bill of Materials"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "name", "ownerId", "drawingData", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Top-level projects"
    },
    "/projects/{projectId}/spools/{spoolId}": {
      "schema": "Spool",
      "description": "Spools within a project"
    }
  }
}
